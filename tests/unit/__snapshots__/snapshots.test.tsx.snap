exports[`MaintainerPanel snapshots > empty state 1`] = `
<section
  aria-label="Maintainer Panel"
  class="maintainer-panel"
>
  <div
    class="panel-columns"
  >
    <div
      class="panel-column"
    >
      <h2
        id="applications-heading"
      >
        Pending Applications
        <span
          aria-atomic="true"
          aria-label="0 pending applications"
          aria-live="polite"
          class="count-badge"
        >
          0
        </span>
      </h2>
      <p
        class="empty-state"
        role="status"
      >
        No pending applications.
      </p>
    </div>
    <div
      class="panel-column"
    >
      <h2
        id="assignments-heading"
      >
        Active Assignments
        <span
          aria-atomic="true"
          aria-label="0 active assignments"
          aria-live="polite"
          class="count-badge"
        >
          0
        </span>
      </h2>
      <p
        class="empty-state"
        role="status"
      >
        No active assignments.
      </p>
    </div>
  </div>
</section>
`;

exports[`MaintainerPanel snapshots > with applications and assignments 1`] = `
<section
  aria-label="Maintainer Panel"
  class="maintainer-panel"
>
  <div
    class="panel-columns"
  >
    <div
      class="panel-column"
    >
      <h2
        id="applications-heading"
      >
        Pending Applications
        <span
          aria-atomic="true"
          aria-label="1 pending applications"
          aria-live="polite"
          class="count-badge"
        >
          1
        </span>
      </h2>
      <ul
        aria-label="Pending applications list"
        aria-labelledby="applications-heading"
        class="panel-list"
      >
        <li
          class="panel-row"
        >
          <div
            class="row-info"
          >
            <span
              aria-label="Contributor: GBXXX1ABCDEFGHIJKLMNO12345"
              class="contributor"
              title="GBXXX1ABCDEFGHIJKLMNO12345"
            >
              GBXXX1AB…O12345
            </span>
            <span
              aria-label="Organisation: stellar-org"
              class="org"
            >
              stellar-org
            </span>
            <span
              aria-label="Issue: Fix bug"
              class="issue-title"
            >
              Fix bug
            </span>
            <time
              aria-label="Applied on 6/20/2026"
              class="date"
              datetime="2026-06-20"
            >
              6/20/2026
            </time>
          </div>
          <div
            class="row-actions"
          >
            <button
              aria-label="Assign Fix bug to GBXXX1AB…O12345"
              class="btn btn-primary btn-sm"
            >
              Assign
            </button>
          </div>
        </li>
      </ul>
    </div>
    <div
      class="panel-column"
    >
      <h2
        id="assignments-heading"
      >
        Active Assignments
        <span
          aria-atomic="true"
          aria-label="1 active assignments"
          aria-live="polite"
          class="count-badge"
        >
          1
        </span>
      </h2>
      <ul
        aria-label="Active assignments list"
        aria-labelledby="assignments-heading"
        class="panel-list"
      >
        <li
          class="panel-row"
        >
          <div
            class="row-info"
          >
            <span
              aria-label="Contributor: GBXXX1ABCDEFGHIJKLMNO12345"
              class="contributor"
              title="GBXXX1ABCDEFGHIJKLMNO12345"
            >
              GBXXX1AB…O12345
            </span>
            <span
              aria-label="Organisation: stellar-org"
              class="org"
            >
              stellar-org
            </span>
            <span
              aria-label="Issue: Optimise WASM"
              class="issue-title"
            >
              Optimise WASM
            </span>
          </div>
          <div
            class="row-actions"
          >
            <button
              aria-busy="false"
              aria-label="Mark Optimise WASM as complete for GBXXX1AB…O12345"
              class="btn btn-complete btn-sm"
            >
              Complete
            </button>
            <button
              aria-busy="false"
              aria-label="Revoke assignment of Optimise WASM from GBXXX1AB…O12345"
              class="btn btn-revoke btn-sm"
            >
              Revoke
            </button>
          </div>
        </li>
      </ul>
    </div>
  </div>
</section>
`;

exports[`NavBar snapshots > connected 1`] = `
<nav
  aria-label="Main navigation"
  class="navbar"
  role="navigation"
>
  <a
    aria-label="WorkloadGovernor home"
    class="navbar__brand"
    href="/"
  >
    <span
      aria-hidden="true"
    >
      ⚙
    </span>
     WorkloadGovernor
  </a>
  <div
    class="navbar__wallet"
  >
    <span
      aria-label="Connected wallet: GBTEST1234ABCD"
      class="navbar__address"
      title="GBTEST1234ABCD"
    >
      GBTEST…ABCD
    </span>
    <button
      aria-label="Disconnect wallet"
      class="btn btn-ghost btn-sm"
    >
      Disconnect
    </button>
  </div>
</nav>
`;

