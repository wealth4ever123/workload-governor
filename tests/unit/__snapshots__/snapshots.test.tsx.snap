    class="issue-card__title"
  >
    Fix TTL bug
  </h3>
  <div
    class="issue-card__actions"
  >
    <button
      aria-busy="false"
      aria-label="Withdraw application for: Fix TTL bug"
      class="btn btn-secondary btn-sm"
    >
      Withdraw
    </button>
  </div>
</article>
`;

