// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ApplicationBadge snapshots > status=assigned 1`] = `
<span
  aria-label="Application status: Assigned"
  class="application-badge application-badge--assigned"
>
  Assigned
</span>
`;

exports[`ApplicationBadge snapshots > status=completed 1`] = `
<span
  aria-label="Application status: Completed"
  class="application-badge application-badge--completed"
>
  Completed
</span>
`;

exports[`ApplicationBadge snapshots > status=pending 1`] = `
<span
  aria-label="Application status: Pending"
  class="application-badge application-badge--pending"
>
  Pending
</span>
`;

exports[`ApplicationBadge snapshots > status=withdrawn 1`] = `
<span
  aria-label="Application status: Withdrawn"
  class="application-badge application-badge--withdrawn"
>
  Withdrawn
</span>
`;

exports[`AssignmentCard snapshots > with actions 1`] = `
<article
  aria-label="Assignment: Optimise WASM size"
  class="assignment-card"
>
  <div
    class="assignment-card__meta"
  >
    <span
      aria-label="Organisation: stellar-org"
      class="assignment-card__org"
    >
      stellar-org
    </span>
    <span
      class="assignment-card__contributor"
      title="GBXXX1ABCDE"
    >
      GBXXX1ABCDE
    </span>
  </div>
  <h3
    class="assignment-card__title"
  >
    Optimise WASM size
  </h3>
  <div
    class="assignment-card__actions"
  >
    <button
      aria-label="Complete: Optimise WASM size"
      class="btn btn-complete btn-sm"
    >
      Complete
    </button>
    <button
      aria-label="Revoke: Optimise WASM size"
      class="btn btn-revoke btn-sm"
    >
      Revoke
    </button>
  </div>
</article>
`;

