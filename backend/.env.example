# =============================================================================
# WorkloadGovernor — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
#
# Legend:
#   required  — the application will not start without this value
#   optional  — a sensible default is used when absent
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# Required: yes
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/workload_governor

# -----------------------------------------------------------------------------
# Cache / Queue
# -----------------------------------------------------------------------------

# Redis connection URL used for caching and job queues.
# Required: yes
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Stellar / Soroban
# -----------------------------------------------------------------------------

# Target Stellar network. One of: testnet | mainnet | futurenet | standalone
# Required: yes
# Default: testnet
STELLAR_NETWORK=testnet

# Deployed WorkloadGovernor contract ID on the target network.
# Required: yes
CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAFCT4

# RPC endpoint for the Stellar network.
# Required: yes
# Default (testnet): https://soroban-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Horizon API endpoint for the Stellar network.
# Required: yes
# Default (testnet): https://horizon-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# -----------------------------------------------------------------------------
# GitHub Integration
# -----------------------------------------------------------------------------

# GitHub personal access token (PAT) or GitHub App token used to read issue
# metadata and validate contributor identities.
# Required: yes
# Minimum scopes: repo:read (public repos) or repo (private repos)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub App ID (only required when using GitHub App auth instead of PAT).
# Required: no
# GITHUB_APP_ID=

# GitHub App private key PEM file path (only required with GitHub App auth).
# Required: no
# GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github_app_private_key.pem

# -----------------------------------------------------------------------------
# HTTP Server
# -----------------------------------------------------------------------------

# Port the Express/Fastify server listens on.
# Required: no
# Default: 3000
PORT=3000

# Host/interface the server binds to.
# Required: no
# Default: 0.0.0.0
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Secret used to sign JWT session tokens. Use a long random string (≥ 32 chars).
# Required: yes
JWT_SECRET=replace_with_a_long_random_secret_string

# Comma-separated list of allowed CORS origins.
# Required: no
# Default: http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Log level. One of: error | warn | info | debug | trace
# Required: no
# Default: info
LOG_LEVEL=info

# Node environment. One of: development | test | production
# Required: no
# Default: development
NODE_ENV=development
