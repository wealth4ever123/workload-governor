# =============================================================================
# WorkloadGovernor — Frontend Environment Variables (Vite)
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
#
# All variables MUST be prefixed with VITE_ to be exposed to client-side code.
#
# Legend:
#   required  — the app will not build/run correctly without this value
#   optional  — a sensible default is used when absent
# =============================================================================

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------

# Base URL of the WorkloadGovernor backend API.
# Required: yes
VITE_API_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Stellar / Soroban
# -----------------------------------------------------------------------------

# Deployed WorkloadGovernor contract ID on the target network.
# Required: yes
VITE_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAFCT4

# Target Stellar network. One of: testnet | mainnet | futurenet | standalone
# Required: yes
# Default: testnet
VITE_STELLAR_NETWORK=testnet

# Soroban RPC URL used by the frontend wallet integration.
# Required: yes
# Default (testnet): https://soroban-testnet.stellar.org
VITE_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Horizon API URL used by the frontend for account and transaction queries.
# Required: yes
# Default (testnet): https://horizon-testnet.stellar.org
VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# -----------------------------------------------------------------------------
# GitHub Integration
# -----------------------------------------------------------------------------

# GitHub OAuth App client ID used for the contributor sign-in flow.
# Required: no (only when GitHub OAuth login is enabled)
# VITE_GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Enable the experimental org selector UI.
# Required: no
# Default: false
VITE_ENABLE_ORG_SELECTOR=false

# -----------------------------------------------------------------------------
# Analytics / Monitoring (optional)
# -----------------------------------------------------------------------------

# Sentry DSN for frontend error tracking. Leave blank to disable Sentry.
# Required: no
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
